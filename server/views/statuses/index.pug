extends ../layouts/application.pug

block header
  = t('views.statuses.name')

block content
  a(class="btn btn-primary" href='/statuses/new' role="button")=t('views.statuses.createNew')
  .table-responsive
    table.table.table-borderless.table-striped.mt-5.bg-white
      thead
        tr
          th.py-3= t('views.statuses.id')
          th.py-3= t('views.statuses.labelName')
          th.py-3= t('views.statuses.createdAt')
          th
      tbody
        each status in statuses
          tr
            td= status.id
            td= status.name
            td= formatDate(status.createdAt)
            td
              .d-flex.flex-wrap
                a.btn.btn-primary.me-1(href='/statuses/' + status.id + '/edit')= t('views.edit')
                +buttonTo('/statuses/' + status.id, 'delete')(class="btn btn-danger" value=t('views.delete'))
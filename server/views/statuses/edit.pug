extends ../layouts/application.pug

block header
  = t('views.statuses.update.header')

block content
  +formFor()(action=`/statuses/${status.id}` method='post')
    +input(status, 'name', errors)(type="text" placeholder=t('views.statuses.new.label'))
    input(name="_method" type="hidden" value="patch")
    +submit(status)(value=t('views.statuses.update.change')) 
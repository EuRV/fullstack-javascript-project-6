extends ../layouts/application.pug

block header
  = t('layouts.application.labels')

block content
  a(class="btn btn-primary mb-5" href='/labels/new' role="button")=t('views.labels.createNew')
  .table-responsive
    table.table.table-borderless.table-striped.mt-5.bg-white
      thead
        tr
          th.py-3= t('views.labels.id')
          th.py-3= t('views.labels.labelName')
          th.py-3= t('views.labels.createdAt')
          th
      tbody
        each label in labels
          tr
            td= label.id
            td= label.name
            td= formatDate(label.createdAt)
            td
              .d-flex.flex-wrap
                a.btn.btn-primary.me-1(href='/labels/' + label.id + '/edit')= t('views.edit')
                +buttonTo('/labels/' + label.id, 'delete')(class="btn btn-danger" value=t('views.delete'))
extends ../layouts/application.pug

block header
  = t('views.labels.edit.header')

block content
  +formFor()(action=`/labels/${label.id}` method='post')
    +input(label, 'name', errors)(type="text" placeholder=t('views.label'))
    input(name="_method" type="hidden" value="patch")
    +submit(label)(value=t('views.edit'))
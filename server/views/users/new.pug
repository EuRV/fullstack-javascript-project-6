extends ../layouts/application.pug

block header
  = t('views.users.new.signUp')

block content
  .row.justify-content-center
    .col-12.col-md-8
      .card.shadow-sm
        .card-body.row.p-5
          +formFor()(action='/users' method='post')
            +input(user, 'firstName', errors)(type="text" placeholder=t('views.users.new.firstName'))
            +input(user, 'lastName', errors)(type="text" placeholder=t('views.users.new.lastName'))
            +input(user, 'email', errors)(type="text" placeholder=t('views.users.new.email'))
            +input(user, 'password', errors)(type="password" placeholder=t('views.users.new.password'))
            +submit(user)(value=t('views.users.new.submit'))